NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Keep false while building locally. Set to true when you want the dashboard
# to require Supabase sign-in.
NEXT_PUBLIC_REQUIRE_AUTH=false

# Optional: defaults to the public KTC sheet currently used by Owen's Hub.
KTC_GOOGLE_SHEET_ID=your-google-sheet-id
KTC_GOOGLE_SHEET_NAME=SF

# Obsidian Local REST API with MCP. Keep this server-only key private.
# Enable the plugin's HTTP server in Obsidian for the default local URL.
OBSIDIAN_API_URL=http://127.0.0.1:27123
OBSIDIAN_API_KEY=your-obsidian-local-rest-api-key
